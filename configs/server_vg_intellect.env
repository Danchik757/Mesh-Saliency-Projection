# Environment template for vg-intellect.
# Source this file before running any launch wrapper:
#   source configs/server_vg_intellect.env
#
# Constraints:
#   - no sudo; all paths must be user-writable
#   - conda environments live under CONDA_ENVS_ROOT
#   - datasets are already present under DATASETS_ROOT
#   - code arrives via git; side inputs (csv/json) arrive via scp
#   - launch large jobs with nice(1) inside tmux

# ---------- repo and project layout ----------
export REPO_ROOT="/home/29d_kon@lab.graphicon.ru/ssd1_link/projects/REPROJECTING/Mesh-Saliency-Projection"
export OUTPUT_ROOT="/home/29d_kon@lab.graphicon.ru/ssd1_link/projects/REPROJECTING/outputs"
export SIDE_INPUTS_ROOT="/home/29d_kon@lab.graphicon.ru/ssd1_link/projects/REPROJECTING/side_inputs"

# ---------- conda ----------
export CONDA_ENVS_ROOT="/home/29d_kon@lab.graphicon.ru/ssd1_link/environments"
# Runtime python for launchers and smoke tests.
export CONDA_ENV_NAME="reproject-benchmark"
export REPROJECT_PYTHON="${CONDA_ENVS_ROOT}/${CONDA_ENV_NAME}/bin/python"

# ---------- dataset roots (already on server) ----------
# "Visual Attention for Rendered 3D Shapes" (3DVA benchmark track)
export VISUAL_ATTENTION_3D_SHAPES_ROOT="/home/29d_kon@lab.graphicon.ru/ssd1_link/datasets/3DVA"
export REPROJECT_DATASET_3DVA_ROOT="${VISUAL_ATTENTION_3D_SHAPES_ROOT}"

# MeshMamba non-texture (face-level GT)
export MESHMAMBA_NON_TEXTURE_ROOT="/home/29d_kon@lab.graphicon.ru/ssd1_link/datasets/MeshMambaSaliency"
export REPROJECT_DATASET_MESHMAMBA_ROOT="${MESHMAMBA_NON_TEXTURE_ROOT}"

# MeshMamba rgb-texture (face-level GT; needs_adaptation — preview not yet validated)
export MESHMAMBA_RGB_TEXTURE_ROOT="/home/29d_kon@lab.graphicon.ru/ssd1_link/datasets/MeshMambaSaliency"
export REPROJECT_DATASET_MESHMAMBA_RGB_TEXTURE_ROOT="${MESHMAMBA_RGB_TEXTURE_ROOT}"

# Saliency3D_clear (screen-space + cone benchmarks)
# Transfer this dataset separately if not already on the server.
export SALIENCY3D_CLEAR_ROOT="/home/29d_kon@lab.graphicon.ru/ssd1_link/datasets/Saliency3D_clear"

# SAL3D — blocked until dense GT reconstruction is available
# export SAL3D_ROOT="/home/29d_kon@lab.graphicon.ru/ssd1_link/datasets/SAL3D"

# ---------- side-input subdirectories (mirror via scp before first run) ----------
# After mirroring, these point into SIDE_INPUTS_ROOT.
# Expected layout under SIDE_INPUTS_ROOT:
#   3DVA/csv/          <- GAZE_DATA/csv_for_models/3DVA/*.csv
#   3DVA/json/         <- GAZE_DATA/jsons_for_models/3DVA_json/*.json
#   MeshMamba_non_texture/csv/   <- GAZE_DATA/csv_for_models/MeshMamba_non_texture/*.csv
#   MeshMamba_non_texture/json/  <- GAZE_DATA/jsons_for_models/Mamba_non_textured/*.json
#   MeshMamba_rgb_texture/csv/   <- GAZE_DATA/csv_for_models/MeshMamba_rgb_texture/*.csv
#   MeshMamba_rgb_texture/json/  <- GAZE_DATA/jsons_for_models/Mamba_rgb_textured/*.json
#   SAL3D/csv/         <- GAZE_DATA/csv_for_models/SAL3D/*.csv  (when available)
#   SAL3D/json/        <- GAZE_DATA/jsons_for_models/SAL3D_json/*.json
export THREE_DVA_CSV_ROOT="${SIDE_INPUTS_ROOT}/3DVA/csv"
export THREE_DVA_JSON_ROOT="${SIDE_INPUTS_ROOT}/3DVA/json"
export THREE_DVA_OUTPUT_DIR="${OUTPUT_ROOT}/3DVA/raycast_cone"

export MESHMAMBA_CSV_ROOT="${SIDE_INPUTS_ROOT}/MeshMamba_non_texture/csv"
export MESHMAMBA_JSON_ROOT="${SIDE_INPUTS_ROOT}/MeshMamba_non_texture/json"
export MESHMAMBA_OUTPUT_DIR="${OUTPUT_ROOT}/MeshMamba_non_texture"

# ---------- external pipeline root (MeshMamba) ----------
# Set this to wherever MAMBA_GAZE was checked out or transferred on the server.
# Required only for our_pipeline / our_pipeline+diffusion / our_pipeline+geodesic_kde.
# Leave empty if only running the in-repo reference methods for MeshMamba.
export MAMBA_GAZE_ROOT="/home/29d_kon@lab.graphicon.ru/ssd1_link/projects/REPROJECTING/MAMBA_GAZE"

# ---------- parallelism ----------
# 12 workers: conservative for 64-CPU EPYC; increase only after checking load in htop.
# No nested parallelism: each run_*.sh script uses a single process pool at WORKERS depth.
export WORKERS=12
export NICE_LEVEL=10
